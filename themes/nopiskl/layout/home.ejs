<%
const data = site.data.projects || {};
const profile = data.profile || {};
const focus = data.focus || [];
const featured = data.featured || [];
const general = data.general || [];
const featuredCount = featured.reduce((sum, category) => sum + ((category.projects || []).length), 0);
const projectCount = featuredCount + general.length;
const docsData = site.data.docs || {};
const docsStats = docsData.stats || {};
%>
<section class="hero">
  <img class="hero-image" src="<%- url_for('/images/nopiskl-hero.png') %>" alt="Nopiskl embedded systems workspace">
  <div class="hero-shade"></div>
  <div class="hero-content">
    <p class="eyebrow">Personal Project Index</p>
    <h1>Nopiskl</h1>
    <p class="hero-kicker"><%= profile.headline %></p>
    <p class="hero-copy"><%= profile.intro %></p>
    <div class="hero-focus" aria-label="工程方向">
      <% focus.forEach(function(item, index) { %>
        <span><b><%= String(index + 1).padStart(2, '0') %></b><%= item %></span>
      <% }) %>
    </div>
    <div class="hero-actions">
      <a class="button primary" href="<%- url_for('/docs/') %>">进入文档库</a>
      <a class="button secondary" href="#projects">查看项目</a>
      <a class="button secondary" href="<%= profile.index_url %>" target="_blank" rel="noopener">GitHub 项目索引</a>
    </div>
  </div>
  <div class="hero-stats" aria-label="project statistics">
    <span><strong><%= featuredCount %></strong><small>重点项目</small></span>
    <span><strong><%= projectCount %></strong><small>项目</small></span>
    <span><strong>Hexo</strong><small>驱动</small></span>
  </div>
</section>

<section class="docs-teaser" id="docs">
  <div class="section-head">
    <div>
      <p class="eyebrow">Documentation</p>
      <h2>文档</h2>
    </div>
    <a class="button primary docs-button" href="<%- url_for('/docs/') %>">进入文档库</a>
  </div>
  <div class="docs-teaser-body">
    <div>
      <strong>项目文档、源码分析和工程笔记</strong>
      <p><%= profile.docs_intro %></p>
    </div>
    <div class="docs-teaser-stats" aria-label="documentation statistics">
      <span><strong><%= docsStats.documents || 0 %></strong><small>文章</small></span>
      <span><strong><%= docsStats.directories || 0 %></strong><small>目录</small></span>
      <span><strong><%= docsStats.attachments || 0 %></strong><small>附件</small></span>
    </div>
  </div>
</section>

<section class="projects-section" id="projects">
  <div class="section-head">
    <div>
      <p class="eyebrow">Projects</p>
      <h2>项目</h2>
    </div>
    <a class="text-link" href="<%= profile.index_url %>" target="_blank" rel="noopener">完整说明在 GitHub</a>
  </div>

  <% featured.forEach(function(category) { %>
    <section class="featured-project-group">
      <div class="featured-group-head">
        <h3><%= category.name %></h3>
        <p><%= category.summary %></p>
      </div>
      <div class="featured-project-grid">
        <% (category.projects || []).forEach(function(project) { %>
          <a class="featured-project-card" href="<%= project.url %>" target="_blank" rel="noopener">
            <% if (project.cover) { %>
              <img class="featured-project-cover" src="<%- url_for(project.cover) %>" alt="">
            <% } %>
            <span class="featured-project-shade"></span>
            <span class="project-status"><%= project.status %></span>
            <strong><%= project.name %></strong>
            <p><%= project.description %></p>
            <% if (project.details && project.details.length) { %>
              <ul>
                <% project.details.forEach(function(detail) { %>
                  <li><%= detail %></li>
                <% }) %>
              </ul>
            <% } %>
          </a>
        <% }) %>
      </div>
    </section>
  <% }) %>

  <div class="project-grid general-project-grid">
    <% general.forEach(function(project) { %>
      <a class="project-card" href="<%= project.url %>" target="_blank" rel="noopener">
        <span class="project-status"><%= project.category %> / <%= project.status %></span>
        <strong><%= project.name %></strong>
        <p><%= project.description %></p>
      </a>
    <% }) %>
  </div>
</section>

<section class="closing-band">
  <div>
    <p class="eyebrow">More Details</p>
    <h2>项目细节持续沉淀在 GitHub</h2>
    <p>博客主页只做轻量索引，具体设计、进度、源码和后续更新以个人项目仓库为准。</p>
  </div>
  <div class="closing-actions">
    <a class="button primary" href="<%= profile.index_url %>" target="_blank" rel="noopener">Nopiskl/Nopiskl</a>
    <a class="button secondary" href="<%= profile.blog_url %>" target="_blank" rel="noopener">CSDN Blog</a>
  </div>
</section>
