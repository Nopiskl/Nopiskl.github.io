<%
const data = site.data.projects || {};
const profile = data.profile || {};
const focus = data.focus || [];
const categories = data.categories || [];
const projectCount = categories.reduce((sum, category) => sum + ((category.projects || []).length), 0);
%>
<section class="hero">
  <img class="hero-image" src="<%- url_for('/images/nopiskl-hero.png') %>" alt="Nopiskl embedded systems workspace">
  <div class="hero-shade"></div>
  <div class="hero-content">
    <p class="eyebrow">Personal Project Index</p>
    <h1>Nopiskl</h1>
    <p class="hero-kicker"><%= profile.headline %></p>
    <p class="hero-copy"><%= profile.intro %></p>
    <div class="hero-actions">
      <a class="button primary" href="#projects">查看项目</a>
      <a class="button secondary" href="<%= profile.index_url %>" target="_blank" rel="noopener">GitHub 项目索引</a>
    </div>
  </div>
  <div class="hero-stats" aria-label="project statistics">
    <span><strong><%= categories.length %></strong><small>方向</small></span>
    <span><strong><%= projectCount %></strong><small>项目</small></span>
    <span><strong>Hexo</strong><small>驱动</small></span>
  </div>
</section>

<section class="focus-section" id="focus">
  <div class="section-head">
    <p class="eyebrow">Focus Areas</p>
    <h2>工程方向</h2>
  </div>
  <div class="focus-grid">
    <% focus.forEach(function(item, index) { %>
      <div class="focus-item">
        <span><%= String(index + 1).padStart(2, '0') %></span>
        <strong><%= item %></strong>
      </div>
    <% }) %>
  </div>
</section>

<section class="projects-section" id="projects">
  <div class="section-head">
    <p class="eyebrow">Projects</p>
    <h2>项目总览</h2>
    <a class="text-link" href="<%= profile.index_url %>" target="_blank" rel="noopener">完整说明在 GitHub</a>
  </div>

  <% categories.forEach(function(category) { %>
    <section class="project-group">
      <div class="group-head">
        <h3><%= category.name %></h3>
        <p><%= category.summary %></p>
      </div>
      <div class="project-grid">
        <% (category.projects || []).forEach(function(project) { %>
          <a class="project-card" href="<%= project.url %>" target="_blank" rel="noopener">
            <span class="project-status"><%= project.status %></span>
            <strong><%= project.name %></strong>
            <p><%= project.description %></p>
          </a>
        <% }) %>
      </div>
    </section>
  <% }) %>
</section>

<section class="closing-band">
  <div>
    <p class="eyebrow">More Details</p>
    <h2>项目细节持续沉淀在 GitHub</h2>
    <p>博客主页只做轻量索引，具体设计、进度、源码和后续更新以个人项目仓库为准。</p>
  </div>
  <div class="closing-actions">
    <a class="button primary" href="<%= profile.index_url %>" target="_blank" rel="noopener">Nopiskl/Nopiskl</a>
    <a class="button secondary" href="<%= profile.blog_url %>" target="_blank" rel="noopener">CSDN Blog</a>
  </div>
</section>
